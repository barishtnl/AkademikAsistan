<UserControl x:Class="AkademikAsistan.App.Views.DersPlani.DersPlaniView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AkademikAsistan.App.ViewModels.DersPlani"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DersPlaniViewModel}"
             Background="{StaticResource ParchmentBrush}">

    <!-- Code-behind'da sadece InitializeComponent() vardır; tüm mantık DersPlaniViewModel'dedir. -->

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="1200" HorizontalAlignment="Left">

            <TextBlock Text="Ders Planı" Style="{StaticResource PageTitleText}"/>
            <TextBlock Text="Haftalık ders programınızı görüntüleyin ve yeni ders ekleyin."
                       Style="{StaticResource BodyText}" Foreground="{StaticResource SlateBrush}"
                       Margin="0,4,0,24"/>

            <!-- ===== Yeni Ders Ekleme Formu ===== -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,28">
                <StackPanel>
                    <TextBlock Text="Yeni Ders Ekle" Style="{StaticResource SectionTitleText}" Margin="0,0,0,16"/>

                    <UniformGrid Columns="3" Rows="3">
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="DERS ADI" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewCourseName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="DERS KODU" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewCourseCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="ÖĞRETİM ÜYESİ" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewInstructorName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="GÜN" Style="{StaticResource LabelText}"/>
                            <ComboBox Style="{StaticResource FormComboBox}" SelectedValuePath="Tag"
                                      SelectedValue="{Binding NewDayOfWeek}">
                                <ComboBoxItem Content="Pazartesi" Tag="1"/>
                                <ComboBoxItem Content="Salı" Tag="2"/>
                                <ComboBoxItem Content="Çarşamba" Tag="3"/>
                                <ComboBoxItem Content="Perşembe" Tag="4"/>
                                <ComboBoxItem Content="Cuma" Tag="5"/>
                                <ComboBoxItem Content="Cumartesi" Tag="6"/>
                                <ComboBoxItem Content="Pazar" Tag="7"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="BAŞLANGIÇ (SS:DD)" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewStartTime, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="BİTİŞ (SS:DD)" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewEndTime, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="DERSLİK" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewClassroom, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="KREDİ" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource FormTextBox}" Text="{Binding NewCredit, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right">
                            <Button Content="Derse Ekle" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddCourseCommand}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                               Margin="0,12,0,0" TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- ===== Haftalık Pano ===== -->
            <TextBlock Text="Haftalık Program" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>

            <ItemsControl ItemsSource="{Binding DayGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Margin="0,0,16,16" Padding="0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                CornerRadius="10" VerticalAlignment="Top">
                            <StackPanel>
                                <Border Background="{StaticResource InkBrush}" CornerRadius="10,10,0,0" Padding="14,10">
                                    <TextBlock Text="{Binding DayName}" Foreground="{StaticResource OnInkBrush}"
                                               FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="15"/>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Courses}" Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource ParchmentBrush}" CornerRadius="8"
                                                    Padding="12,10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" Content="✕" Width="20" Height="20"
                                                                Padding="0" FontSize="10" Background="Transparent"
                                                                BorderThickness="0" Cursor="Hand"
                                                                Foreground="{StaticResource SlateBrush}"
                                                                Command="{Binding DataContext.DeleteCourseCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}"
                                                                CommandParameter="{Binding}"/>
                                                        <TextBlock Text="{Binding CourseName}" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource BodyFont}"
                                                                   Foreground="{StaticResource InkBrush}" TextWrapping="Wrap"/>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource SlateBrush}">
                                                        <Run Text="{Binding StartTime, Mode=OneWay}"/>
                                                        <Run Text=" – "/>
                                                        <Run Text="{Binding EndTime, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Classroom}" FontSize="12"
                                                               Foreground="{StaticResource SlateBrush}"
                                                               Visibility="{Binding Classroom, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
