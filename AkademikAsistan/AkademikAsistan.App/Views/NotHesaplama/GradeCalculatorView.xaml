<UserControl x:Class="AkademikAsistan.App.Views.NotHesaplama.GradeCalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AkademikAsistan.App.ViewModels.NotHesaplama"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:GradeCalculatorViewModel}"
             Background="{StaticResource ParchmentBrush}">

    <!-- Code-behind'da sadece InitializeComponent() vardır. -->

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="680" HorizontalAlignment="Left">

            <TextBlock Text="Not Hesaplama" Style="{StaticResource PageTitleText}"/>
            <TextBlock Text="Ağırlıklı not ortalamanızı ve harf notunuzu hesaplayın."
                       Style="{StaticResource BodyText}" Foreground="{StaticResource SlateBrush}"
                       Margin="0,4,0,28"/>

            <!-- ===== Vize ===== -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VİZE NOTU" Style="{StaticResource LabelText}"/>
                        <TextBox Style="{StaticResource FormTextBox}"
                                 Text="{Binding MidtermScore, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="VİZE AĞIRLIĞI (%)" Style="{StaticResource LabelText}"/>
                        <TextBox Style="{StaticResource FormTextBox}"
                                 Text="{Binding MidtermWeight, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Final ===== -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FİNAL NOTU" Style="{StaticResource LabelText}"/>
                        <TextBox Style="{StaticResource FormTextBox}"
                                 Text="{Binding FinalScore, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="FİNAL AĞIRLIĞI (%)" Style="{StaticResource LabelText}"/>
                        <TextBox Style="{StaticResource FormTextBox}"
                                 Text="{Binding FinalWeight, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Butonlar ===== -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Hesapla" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CalculateCommand}" Margin="0,0,12,0"/>
                <Button Content="Sıfırla" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetCommand}"/>
            </StackPanel>

            <!-- ===== Hata Mesajı ===== -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontFamily="{StaticResource BodyFont}" FontSize="13"
                       TextWrapping="Wrap" Margin="0,14,0,0"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

            <!-- ===== Sonuç Kartı ===== -->
            <Border Style="{StaticResource CardBorder}" Margin="0,24,0,0"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="SONUÇ" Style="{StaticResource LabelText}"/>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,4">
                            <Run Text="Ağırlıklı Ortalama: "/>
                            <Run Text="{Binding ResultWeightedScore, Mode=OneWay}"
                                 FontWeight="Bold" FontFamily="Consolas"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}">
                            <Run Text="Katsayı (GPA): "/>
                            <Run Text="{Binding ResultGradePoint, Mode=OneWay}"
                                 FontWeight="Bold" FontFamily="Consolas"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Harf Notu — büyük vurgu -->
                    <Border Grid.Column="1" Background="{StaticResource InkBrush}"
                            CornerRadius="10" Padding="24,16" Margin="16,0,0,0"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="HARF NOTU" Foreground="#7E91BC"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ResultLetterGrade, Mode=OneWay}"
                                       Foreground="{StaticResource CoralBrush}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="48" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
