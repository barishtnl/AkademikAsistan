<Window x:Class="AkademikAsistan.App.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AkademikAsistan.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Akademik Asistan"
        Height="760" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ParchmentBrush}">

    <!--
        ViewModel-first navigasyon: Sol sidebar'daki RadioButton'lar NavigateCommand'i
        tetikler. ContentControl, MainViewModel.CurrentViewModel tipine göre
        App.xaml'deki DataTemplate eşlemesini kullanarak doğru View'i yükler.
        Code-behind'da hiçbir View değiştirme kodu yoktur.
    -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="{StaticResource InkBrush}">
            <DockPanel>

                <!-- Logo / Başlık -->
                <Border DockPanel.Dock="Top" Padding="20,28,20,20">
                    <StackPanel>
                        <TextBlock Text="🎓" FontSize="32" HorizontalAlignment="Left"/>
                        <TextBlock Text="Akademik" Foreground="White"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="Asistan" Foreground="{StaticResource CoralBrush}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Ayraç -->
                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#2E3D63" Margin="16,0"/>

                <!-- Menü başlığı -->
                <TextBlock DockPanel.Dock="Top" Text="MODÜLLER"
                           Foreground="#5A6A8E" FontSize="10" FontWeight="Bold"
                           FontFamily="{StaticResource BodyFont}"
                           Margin="20,18,0,8"/>

                <!-- Navigasyon butonları -->
                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding ActiveModule,
                                     Converter={StaticResource StringEqualsConverter},
                                     ConverterParameter=DersPlani,
                                     Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="DersPlani">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Ders Planı" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding ActiveModule,
                                     Converter={StaticResource StringEqualsConverter},
                                     ConverterParameter=NotHesaplama,
                                     Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="NotHesaplama">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧮" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Not Hesaplama" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButton}"
                                 IsChecked="{Binding ActiveModule,
                                     Converter={StaticResource StringEqualsConverter},
                                     ConverterParameter=GelisimTakibi,
                                     Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="GelisimTakibi">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Gelişim Takibi" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Alt bilgi -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0 · 2025–2026 Güz"
                           Foreground="#3A4D75" FontSize="11"
                           FontFamily="{StaticResource BodyFont}"
                           Margin="20,0,0,20"/>

            </DockPanel>
        </Border>

        <!-- ===== İÇERİK ALANI ===== -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"
                        Focusable="False"/>

    </Grid>
</Window>
