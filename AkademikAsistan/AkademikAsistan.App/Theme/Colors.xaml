<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Tasarım Dili — "Akademik Asistan"
        Palet: koyu mürekkep lacivert (sidebar/başlıklar) + sıcak parşömen arka plan
        + mercan vurgu (aksiyon) + adaçayı yeşili (pozitif/başarı: not, GNO artışı).
        Tipografi: başlıklarda Cambria (akademik/serif karakter), gövdede Segoe UI,
        sayısal verilerde (not, GPA) Consolas — tablo/rakam hissi için.
    -->

    <!-- ===================== Renkler ===================== -->
    <Color x:Key="InkColor">#1C2541</Color>
    <Color x:Key="InkLightColor">#2C3A60</Color>
    <Color x:Key="ParchmentColor">#F7F4EE</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="CoralColor">#E07856</Color>
    <Color x:Key="CoralDarkColor">#C9603F</Color>
    <Color x:Key="SageColor">#5B8C72</Color>
    <Color x:Key="SlateColor">#6B7280</Color>
    <Color x:Key="BorderColor">#E4DFD3</Color>
    <Color x:Key="DangerColor">#C0463A</Color>

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}"/>
    <SolidColorBrush x:Key="InkLightBrush" Color="{StaticResource InkLightColor}"/>
    <SolidColorBrush x:Key="ParchmentBrush" Color="{StaticResource ParchmentColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CoralBrush" Color="{StaticResource CoralColor}"/>
    <SolidColorBrush x:Key="CoralDarkBrush" Color="{StaticResource CoralDarkColor}"/>
    <SolidColorBrush x:Key="SageBrush" Color="{StaticResource SageColor}"/>
    <SolidColorBrush x:Key="SlateBrush" Color="{StaticResource SlateColor}"/>
    <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="OnInkBrush" Color="#F2EFE8"/>

    <!-- ===================== Tipografi ===================== -->
    <FontFamily x:Key="DisplayFont">Cambria</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="DataFont">Consolas</FontFamily>

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SlateBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

    <Style x:Key="DataNumberText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DataFont}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

</ResourceDictionary>
